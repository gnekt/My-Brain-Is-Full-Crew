{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "CREW_PLATFORM_DIR=.codex bash .codex/hooks/protect-system-files.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "CREW_PLATFORM_DIR=.codex bash .codex/hooks/validate-frontmatter.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .codex/hooks/notify.sh"
          }
        ]
      }
    ]
  }
}
