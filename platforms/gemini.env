# Platform: Gemini CLI
# Role: Variable map for Gemini CLI template expansion

# Tool variables — names used in frontmatter tools: field and body text
TOOL_READ=read_file
TOOL_WRITE=write_file
TOOL_EDIT=replace
TOOL_BASH=run_shell_command
TOOL_GLOB=glob
TOOL_GREP=grep_search
TOOL_AGENT=activate_skill
TOOL_SKILL=activate_skill
TOOL_ASK=ask_user

# Model variables — model tier references in frontmatter model: field
MODEL_FAST=gemini-2.5-flash
MODEL_POWERFUL=gemini-2.5-pro
MODEL_LIGHT=gemini-2.5-flash

# Path and platform variables
PLATFORM_DIR=.gemini
PLATFORM_NAME="Gemini CLI"
DISPATCHER_FILE=GEMINI.md
