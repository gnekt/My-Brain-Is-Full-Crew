MODEL_POWERFUL=anthropic/claude-opus-4-6
MODEL_LIGHT=anthropic/claude-haiku-3-5

# Path and platform variables
PLATFORM_DIR=.opencode
PLATFORM_NAME="OpenCode"
DISPATCHER_FILE=AGENTS.md
