# Platform: Codex CLI (OpenAI)
# Role: Variable map for Codex CLI template expansion

# Tool variables — names used in frontmatter tools: field and body text
TOOL_READ=read_file
TOOL_WRITE=write_file
TOOL_EDIT=apply_patch
TOOL_BASH=shell
TOOL_GLOB=glob
TOOL_GREP=search
TOOL_AGENT=spawn_agent
TOOL_SKILL=skill
TOOL_ASK=ask_user

# Model variables — model tier references in frontmatter model: field
MODEL_FAST=o4-mini
MODEL_POWERFUL=o3
MODEL_LIGHT=o4-mini

# Path and platform variables
PLATFORM_DIR=.codex
PLATFORM_NAME="Codex CLI"
DISPATCHER_FILE=AGENTS.md
